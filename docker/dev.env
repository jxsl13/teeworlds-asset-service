# =============================================================================
# Teeworlds Asset Database — Development Environment
# =============================================================================
# Shared by the server, docker-compose, and launch.json.
#
# Quick start:
#   make db-up                # start PostgreSQL
#   make pocketid-provision   # one-time OIDC setup (updates this file)
#   set -a && . docker/dev.env && set +a && go run .   # start the server
#
# Seed DDNet skins (optional, server must be running):
#   make seed-ddnet-skins
# =============================================================================

# --- Database ----------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=search
DB_PASSWORD=search
DB_NAME=search
DB_SSLMODE=disable

# --- Server ------------------------------------------------------------------
ADDR=:8080
INSECURE=true                 # allow non-HTTPS cookies for local dev

# --- Storage -----------------------------------------------------------------
STORAGE_PATH=./testdata
MAX_STORAGE_SIZE=1GiB

# --- pgAdmin (Docker only) --------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_SERVER_MODE=False
PGADMIN_MASTER_PASSWORD_REQUIRED=False

# --- Pocket-ID / OIDC -------------------------------------------------------
# OIDC_CLIENT_ID and OIDC_CLIENT_SECRET are written by:
#   make pocketid-provision
# Run it once after 'make db-up' before starting the server.
OIDC_ISSUER_URL=https://localhost:1411
OIDC_CLIENT_ID=bf0cf3a6-3942-4593-8c5a-b34833144bff
OIDC_CLIENT_SECRET=TptytzPREkLWmYsZd3xMq5zu7A4LBjTp
OIDC_REDIRECT_URL=http://localhost:8080/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URL=http://localhost:8080/auth/post-logout

# --- Pocket-ID provisioning (cmd/provision-pocketid) -------------------------
POCKET_ID_ENCRYPTION_KEY=dev-encryption-key-min16
POCKET_ID_STATIC_API_KEY=dev-static-api-key-for-provisioning
POCKET_ID_ADMIN_EMAIL=admin@example.com
POCKET_ID_CLIENT_NAME="Teeworlds Asset Database Dev"
