# shared by asset-service, docker-compose and launch.json
DB_HOST=localhost
DB_PORT=5432
DB_USER=search
DB_PASSWORD=search
DB_NAME=search
DB_SSLMODE=disable
ADDR=:8080
STORAGE_PATH=./testdata
MAX_STORAGE_SIZE=1GiB

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_SERVER_MODE=False
PGADMIN_MASTER_PASSWORD_REQUIRED=False

# Pocket-ID (OIDC)
OIDC_ISSUER_URL=https://localhost:1411
OIDC_REDIRECT_URL=http://localhost:8080/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URL=http://localhost:8080/auth/post-logout
POCKET_ID_ENCRYPTION_KEY=dev-encryption-key-min16
POCKET_ID_STATIC_API_KEY=dev-static-api-key-for-provisioning
POCKET_ID_ADMIN_EMAIL=admin@example.com
POCKET_ID_CLIENT_NAME="Asset Service Dev"
INSECURE=true
